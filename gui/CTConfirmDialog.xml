<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<!--
    CTConfirmDialog — FS25_CustomTriggerCreator
    Generic Yes/No confirmation used before activating triggers
    that require player acknowledgement, and within chained flows.
-->
<GUI onOpen="onDialogOpen" onClose="onDialogClose" onCreate="onCreate">
    <GuiElement profile="newLayer" />
    <Bitmap profile="dialogFullscreenBg" id="dialogBg" />

    <GuiElement profile="dialogBg" id="dialogElement" size="520px 340px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle" />
        <ThreePartBitmap profile="fs25_dialogBgTop" />
        <ThreePartBitmap profile="fs25_dialogBgBottom" />

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title -->
            <Text profile="cfTitle"   id="cfTitleText"   position="0px -18px" text="Confirm"/>
            <!-- Message (two lines for longer text) -->
            <Text profile="cfMessage" id="cfMessageLine1" position="0px -55px" text=""/>
            <Text profile="cfMessage" id="cfMessageLine2" position="0px -78px" text=""/>

            <!-- Divider -->
            <Bitmap profile="cfDivider" position="0px -105px"/>

            <!-- Detail info -->
            <Text profile="cfDetail"  id="cfDetailText"  position="0px -118px" text=""/>

            <!-- Yes button (3-layer) -->
            <Bitmap profile="cfYesBg"   id="cfYesBg"   position="-100px -160px"/>
            <Text   profile="cfYesText" id="cfYesText" position="-100px -164px" text="Yes"/>
            <Button profile="cfYesHit"  id="cfYesBtn"  position="-100px -160px" onClick="onClickYes"/>

            <!-- No button (3-layer) -->
            <Bitmap profile="cfNoBg"   id="cfNoBg"   position="100px -160px"/>
            <Text   profile="cfNoText" id="cfNoText" position="100px -164px" text="No"/>
            <Button profile="cfNoHit"  id="cfNoBtn"  position="100px -160px" onClick="onClickNo"/>

        </GuiElement>

        <BoxLayout profile="fs25_dialogButtonBox"/>

    </GuiElement>

    <GUIProfiles>
        <Profile name="fs25_guiElement" extends="baseReference"/>

        <Profile name="cfTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="460px 24px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="cfMessage" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="440px 20px"/>
            <textSize value="14px"/>
            <textColor value="0.85 0.85 0.85 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="cfDivider" extends="baseReference" with="anchorTopCenter">
            <size value="440px 1px"/>
            <imageColor value="0.3 0.35 0.45 0.8"/>
        </Profile>
        <Profile name="cfDetail" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="440px 18px"/>
            <textSize value="12px"/>
            <textColor value="0.55 0.6 0.7 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Yes (green) -->
        <Profile name="cfYesBg"   extends="baseReference" with="anchorTopCenter">
            <size value="160px 44px"/>
            <imageColor value="0.10 0.28 0.12 0.95"/>
        </Profile>
        <Profile name="cfYesText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="160px 34px"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textColor value="0.65 1 0.65 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="cfYesHit"  extends="emptyPanel" with="anchorTopCenter">
            <size value="160px 44px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- No (red) -->
        <Profile name="cfNoBg"   extends="baseReference" with="anchorTopCenter">
            <size value="160px 44px"/>
            <imageColor value="0.28 0.08 0.08 0.95"/>
        </Profile>
        <Profile name="cfNoText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="160px 34px"/>
            <textSize value="16px"/>
            <textBold value="true"/>
            <textColor value="1 0.60 0.60 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="cfNoHit"  extends="emptyPanel" with="anchorTopCenter">
            <size value="160px 44px"/>
            <isFocusable value="true"/>
        </Profile>
    </GUIProfiles>
</GUI>
